# Copy to .env and fill in values from your Supabase project
# (Project Settings -> API)

# Public project URL, e.g. https://abcdefgh.supabase.co
SUPABASE_URL=

# Public/publishable (anon) key. Safe to expose. Used for auth flows and for
# building per-request, RLS-enforced clients. The server holds NO admin key.
SUPABASE_ANON_KEY=

# Port the API listens on (deploy platforms set this automatically).
PORT=3000
